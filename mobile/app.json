{
  "expo": {
    "name": "Bonde OS Mobile",
    "slug": "bonde-os-mobile",
    "version": "1.0.0",
    "platforms": [
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.bonde.os.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiBaseUrl": "https://dolese.tech/api"
    }
  }
}
