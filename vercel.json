{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/classes/:id/students/bulk",
      "destination": "/api/classes/[id]/students/bulk.js?id=:id"
    },
    {
      "source": "/api/classes/:id/students/:sid",
      "destination": "/api/classes/[id]/students/[sid].js?id=:id&sid=:sid"
    },
    {
      "source": "/api/classes/:id/students",
      "destination": "/api/classes/[id]/students/index.js?id=:id"
    },
    {
      "source": "/api/classes/:id/publish",
      "destination": "/api/classes/[id]/publish/index.js?id=:id"
    },
    {
      "source": "/api/classes/:id/audit",
      "destination": "/api/classes/[id]/audit/index.js?id=:id"
    },
    {
      "source": "/api/classes/:id",
      "destination": "/api/classes/[id]/index.js?id=:id"
    },
    {
      "source": "/api/students/search",
      "destination": "/api/students/search.js"
    },
    {
      "source": "/api/students/:indexNo/profile",
      "destination": "/api/students/[indexNo].js?indexNo=:indexNo"
    },
    {
      "source": "/api/proxy-csv",
      "destination": "/api/proxy-csv/index.js"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/index.js?action=login"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth/index.js?action=me"
    },
    {
      "source": "/api/auth/change-password",
      "destination": "/api/auth/index.js?action=change-password"
    },
    {
      "source": "/api/auth/users",
      "destination": "/api/auth/index.js?action=users"
    },
    {
      "source": "/api/auth/users/:username",
      "destination": "/api/auth/index.js?action=user&username=:username"
    },
    {
      "source": "/api/backup",
      "destination": "/api/stats/index.js"
    },
    {
      "source": "/api/restore",
      "destination": "/api/stats/index.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/stats/index.js"
    },
    {
      "source": "/api/homepage",
      "destination": "/api/stats/index.js?overview=1"
    },
    {
      "source": "/api/stats",
      "destination": "/api/stats/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/asset/:path*",
      "destination": "/frontend/asset/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/frontend/static/:path*"
    },
    {
      "source": "/asset-manifest.json",
      "destination": "/frontend/asset-manifest.json"
    },
    {
      "source": "/manifest.json",
      "destination": "/frontend/manifest.json"
    },
    {
      "source": "/favicon.ico",
      "destination": "/frontend/favicon.ico"
    },
    {
      "source": "/logo192.png",
      "destination": "/frontend/logo192.png"
    },
    {
      "source": "/logo512.png",
      "destination": "/frontend/logo512.png"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
