{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/classes/:id/students/bulk",
      "destination": "/api/index.js?dispatch=class-students-bulk&id=:id"
    },
    {
      "source": "/api/classes/:id/students/:sid",
      "destination": "/api/index.js?dispatch=class-student&id=:id&sid=:sid"
    },
    {
      "source": "/api/classes/:id/students",
      "destination": "/api/index.js?dispatch=class-students&id=:id"
    },
    {
      "source": "/api/classes/:id/publish",
      "destination": "/api/index.js?dispatch=class-publish&id=:id"
    },
    {
      "source": "/api/classes/:id/audit",
      "destination": "/api/index.js?dispatch=class-audit&id=:id"
    },
    {
      "source": "/api/classes/:id",
      "destination": "/api/index.js?dispatch=class&id=:id"
    },
    {
      "source": "/api/students/search",
      "destination": "/api/index.js?dispatch=students-search"
    },
    {
      "source": "/api/students/:indexNo/profile",
      "destination": "/api/index.js?dispatch=student-profile&indexNo=:indexNo"
    },
    {
      "source": "/api/proxy-csv",
      "destination": "/api/index.js?dispatch=proxy-csv"
    },
    {
      "source": "/api/sms",
      "destination": "/api/index.js?dispatch=sms"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/index.js?dispatch=auth-login"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/index.js?dispatch=auth-me"
    },
    {
      "source": "/api/auth/change-password",
      "destination": "/api/index.js?dispatch=auth-change-password"
    },
    {
      "source": "/api/auth/users",
      "destination": "/api/index.js?dispatch=auth-users"
    },
    {
      "source": "/api/auth/users/:username",
      "destination": "/api/index.js?dispatch=auth-user&username=:username"
    },
    {
      "source": "/api/backup",
      "destination": "/api/index.js?dispatch=backup"
    },
    {
      "source": "/api/restore",
      "destination": "/api/index.js?dispatch=restore"
    },
    {
      "source": "/api/health",
      "destination": "/api/index.js?dispatch=health"
    },
    {
      "source": "/api/homepage",
      "destination": "/api/index.js?dispatch=homepage"
    },
    {
      "source": "/api/stats",
      "destination": "/api/index.js?dispatch=stats"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js?dispatch=not-found"
    },
    {
      "source": "/asset/:path*",
      "destination": "/frontend/asset/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/frontend/static/:path*"
    },
    {
      "source": "/asset-manifest.json",
      "destination": "/frontend/asset-manifest.json"
    },
    {
      "source": "/manifest.json",
      "destination": "/frontend/manifest.json"
    },
    {
      "source": "/favicon.ico",
      "destination": "/frontend/favicon.ico"
    },
    {
      "source": "/logo192.png",
      "destination": "/frontend/logo192.png"
    },
    {
      "source": "/logo512.png",
      "destination": "/frontend/logo512.png"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
